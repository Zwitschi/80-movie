# Control room environment variables
# Copy to repo-root .env for local development or set in Coolify.

# Required in production
DATABASE_URL=postgresql://user:password@localhost/omo
SECRET_KEY=change-me-to-random-hex
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=change-me-to-werkzeug-hash

# Optional
OMO_BOT_API_URL=https://api.openmicodyssey.com
CONTROL_ROOM_AUTO_CREATE=1
