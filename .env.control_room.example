# Control Room Environment Variables
# Copy to .env in control_room/ directory or set in Coolify

# Required
DATABASE_URL=postgresql://user:pass@192.168.88.35:5432/omo
SECRET_KEY=change-me-to-random-hex

# Discord OAuth (required for operator login)
OMO_DISCORD_CLIENT_ID=
OMO_DISCORD_CLIENT_SECRET=
OMO_DISCORD_REDIRECT_URI=https://admin.openmicodyssey.com/oauth/discord/callback

# Operator Access Control
OMO_BOT_OPS_ALLOWED_USER_IDS=
OMO_BOT_OPS_DEFAULT_SCOPES=ops.read
OMO_BOT_OPS_SESSION_IDLE_MINUTES=60
