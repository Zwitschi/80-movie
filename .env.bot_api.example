# Bot API environment variables
# Copy to repo-root .env for local development or set in Coolify.

# Required in production
OMO_DATABASE_URL=postgresql://user:password@localhost/omo
SECRET_KEY=change-me-to-random-hex
OMO_DISCORD_CLIENT_ID=
OMO_DISCORD_CLIENT_SECRET=
OMO_DISCORD_REDIRECT_URI=https://api.openmicodyssey.com/oauth/discord/callback

# Recommended operator access defaults
OMO_BOT_OPS_ALLOWED_USER_IDS=
OMO_BOT_OPS_DEFAULT_SCOPES=ops.read
OMO_BOT_OPS_SESSION_IDLE_MINUTES=60

# Optional runtime-backed diagnostics and views
OMO_DISCORD_TOKEN=
OMO_DISCORD_GUILD_ID=
OMO_SYNDICATION_SOURCES=youtube
OMO_SYNDICATION_POLL_SECONDS=300
OMO_LOG_LEVEL=INFO

# Legacy fallback if you do not use OMO_DATABASE_URL
# DATABASE_URL=postgresql://user:password@localhost/omo
