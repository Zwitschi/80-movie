# Copy to website/.env for local use. Do not commit real secrets.

# Website runtime
SITE_URL=https://example.com
SECRET_KEY=replace-with-long-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=replace-with-werkzeug-password-hash
DATA_SOURCE=DB
CURRENT_YEAR=2026

# External services
MAPBOX_ACCESS_TOKEN=pk.your_mapbox_public_token

# Shared database connection (website + bot fallback)
DATABASE_URL=postgresql://username:password@host:port/dbname

# Dedicated bot database override
OMO_DATABASE_URL=postgresql://username:password@host:port/dbname

# Embedded control-room OAuth
OMO_DISCORD_CLIENT_ID=your-discord-oauth-client-id
OMO_DISCORD_CLIENT_SECRET=your-discord-oauth-client-secret
OMO_DISCORD_REDIRECT_URI=http://localhost:5000/oauth/discord/callback
OMO_BOT_OPS_ALLOWED_USER_IDS=123456789012345678
OMO_BOT_OPS_DEFAULT_SCOPES=ops.read,syndication.write
OMO_BOT_OPS_SESSION_IDLE_MINUTES=60

# Discord bot worker credentials
OMO_DISCORD_TOKEN=your-discord-bot-token
OMO_DISCORD_GUILD_ID=your-discord-guild-id
OMO_DISCORD_CHANNEL_MAP=queue:100,announcements:200
OMO_SYNDICATION_SOURCES=youtube
OMO_SYNDICATION_POLL_SECONDS=300
OMO_LOG_LEVEL=INFO

# Legacy aliases still supported, but prefer OMO_* names above
DISCORD_TOKEN=your-discord-bot-token
DISCORD_CLIENT_ID=your-discord-oauth-client-id
DISCORD_CLIENT_SECRET=your-discord-oauth-client-secret
DISCORD_REDIRECT_URI=http://localhost:5000/oauth/discord/callback
