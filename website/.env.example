# Copy to website/.env for local use. Do not commit real secrets.

# Deployment settings
WEBSITE_DEPLOY_REPOSITORY=your-repo-name
WEBSITE_DEPLOY_BRANCH=build
WEBSITE_DEPLOY_TOKEN=ghp_your_token_here

# App behavior
ALLOW_INDEXING=true
SITE_URL=https://example.com
CURRENT_YEAR=2026

# External services
HEROKU_API_KEY=your-heroku-api-key
MAPBOX_ACCESS_TOKEN=pk.your_mapbox_public_token

# Database connection (PostgreSQL)
DATABASE_URL=postgresql://username:password@host:port/dbname