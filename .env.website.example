# Website Environment Variables
# Copy to .env in website/ directory or set in Coolify

# Required
SITE_URL=https://www.openmicodyssey.com
DATABASE_URL=postgresql://user:pass@192.168.88.35:5432/omo
SECRET_KEY=change-me-to-random-hex
ADMIN_PASSWORD_HASH=change-me-to-werkzeug-hash

# Optional
ADMIN_USERNAME=admin
CURRENT_YEAR=2026
MAPBOX_ACCESS_TOKEN=
DATA_SOURCE=DB

# Control Room (optional, for embedded /admin/bot)
OMO_DISCORD_CLIENT_ID=
OMO_DISCORD_CLIENT_SECRET=
OMO_DISCORD_REDIRECT_URI=https://www.openmicodyssey.com/oauth/discord/callback
OMO_BOT_OPS_ALLOWED_USER_IDS=
OMO_BOT_OPS_DEFAULT_SCOPES=ops.read
OMO_BOT_OPS_SESSION_IDLE_MINUTES=60
