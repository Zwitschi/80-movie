# Bot worker environment variables
# Copy to repo-root .env for local development or set in your worker host.

# Required to start the worker
OMO_DISCORD_TOKEN=
OMO_DATABASE_URL=postgresql://user:password@localhost/omo

# Optional
OMO_DISCORD_GUILD_ID=
OMO_DISCORD_CHANNEL_MAP=queue:100,announcements:200
OMO_SYNDICATION_SOURCES=youtube
OMO_SYNDICATION_POLL_SECONDS=300
OMO_LOG_LEVEL=INFO

# Legacy fallbacks
# DISCORD_TOKEN=
# DATABASE_URL=postgresql://user:password@localhost/omo